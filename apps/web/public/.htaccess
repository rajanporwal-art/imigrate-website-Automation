# Block direct access to the stored leads data (also protected inside /leads).
<FilesMatch "\.ndjson$">
	Require all denied
</FilesMatch>

# Never expose the Basic-Auth password file or content backups over the web.
<FilesMatch "(^\.htpasswd$|\.backup$)">
	Require all denied
</FilesMatch>

# ============================================================
# HTTP BASIC AUTH on the admin dashboard + its endpoints (OPTIONAL, DISABLED).
#
# This is extra, server-level protection. It is DISABLED by default so the
# site runs cleanly the moment you upload it — admin access is already
# restricted by the app's server-validated password gate (admin-verify.php).
#
# TO ENABLE (recommended hardening), do BOTH:
#   1. Set AuthUserFile to the ABSOLUTE server path to .htpasswd. On Hostinger:
#        /home/uXXXXXXXXX/domains/imigratesolution.com/public_html/.htpasswd
#      (hPanel → File Manager → right-click .htpasswd → "Get info"/path)
#   2. Remove the "# " from the start of the five lines below.
# Login already created in .htpasswd —  user: imigrate-admin
#
# ⚠️ If the path is wrong these admin files return HTTP 500 (the public site is
#    unaffected — the rule is scoped to admin files only). Fix the path or
#    re-comment the lines to recover.
# ============================================================
# <FilesMatch "^(admin\.html|admin-verify\.php|save-content\.php|leads-read\.php|lead-file\.php|lead-upload\.php)$">
# 	AuthType Basic
# 	AuthName "iMigrate Admin — authorized access only"
# 	AuthUserFile "/home/REPLACE_WITH_YOUR_ABSOLUTE_PATH/public_html/.htpasswd"
# 	Require valid-user
# </FilesMatch>

<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteBase /

	# ============================================================
	# CANONICAL HOST — force non-www → www (matches sitemap, robots.txt
	# and the canonical tags the app emits). Prevents duplicate content
	# and split indexing across www / non-www. Keep at the top.
	# ============================================================
	RewriteCond %{HTTP_HOST} ^imigratesolution\.com$ [NC]
	RewriteRule ^(.*)$ https://www.imigratesolution.com/$1 [R=301,L]

	# ============================================================
	# 301 REDIRECTS — old Wix /post/ blog URLs → new /blog/ URLs.
	# Preserves SEO value from the previous site. Keep above the SPA fallback.
	# ============================================================
	Redirect 301 /post/simplifying-migration-with-immigration-process-assistance /blog/simplifying-migration-with-immigration-process-assistance
	Redirect 301 /post/australia-skilled-migration-visa-update-2025-step-by-step-process-latest-updates /blog/australia-skilled-migration-visa-update-2025-step-by-step-process-latest-updates
	Redirect 301 /post/it-jobs-in-australia-your-comprehensive-guide-with-imigrate-migration-solutions /blog/it-jobs-in-australia-your-comprehensive-guide-with-imigrate-migration-solutions
	Redirect 301 /post/is-melbourne-expensive-a-deep-dive-into-the-cost-of-living /blog/is-melbourne-expensive-a-deep-dive-into-the-cost-of-living
	Redirect 301 /post/your-path-to-an-it-career-in-australia-a-comprehensive-guide /blog/your-path-to-an-it-career-in-australia-a-comprehensive-guide
	Redirect 301 /post/thriving-in-regional-australia-your-guide-to-a-fulfilling-lifestyle /blog/thriving-in-regional-australia-your-guide-to-a-fulfilling-lifestyle
	Redirect 301 /post/exploring-job-opportunities-in-sydney-in-2024-a-comprehensive-guide /blog/exploring-job-opportunities-in-sydney-in-2024-a-comprehensive-guide
	# Catch-all: any other old /post/* URL → the blog index (prevents broken links)
	RewriteRule ^post/(.*)$ /blog [R=301,L]
	# ============================================================

	# Dynamic XML sitemap (auto-includes blog posts)
	RewriteRule ^sitemap\.xml$ sitemap.php [L]

	# Safeguard: 404 stray nested folders left by earlier deploy-path setup so
	# they can't be indexed (delete public_html/, domains/, home/ from the web
	# root via File Manager to remove fully). No real route uses these names.
	RewriteRule ^(public_html|domains|home)(/|$) - [R=404,L]

	# SPA fallback — send all other routes to the app (do not move above redirects)
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
	# Never cache the editable content files so edits appear immediately
	<FilesMatch "(content|blog|faqs|hubspot|forms)\.json$">
		Header set Cache-Control "no-cache, no-store, must-revalidate"
	</FilesMatch>
</IfModule>
